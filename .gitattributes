# Normalize text line endings to LF in the repository. Working-tree
# files check out with LF on all platforms — no CRLF/LF noise in
# `git status` from Windows clients.
* text=auto eol=lf

# Windows-only scripts must stay CRLF — cmd.exe refuses to parse .bat
# files with LF-only endings.
*.bat text eol=crlf
*.cmd text eol=crlf
